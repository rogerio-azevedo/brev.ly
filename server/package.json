{
  "name": "brev-server",
  "version": "1.0.0",
  "type": "module",
  "description": "",
  "scripts": {
    "dev": "tsx watch --env-file .env src/infra/http/server.ts",
    "build": "tsup",
    "start": "node dist/server.js",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "tsx --env-file .env node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:local": "tsx --env-file .env node_modules/drizzle-kit/bin.cjs migrate",
    "db:migrate:test": "tsx --env-file .env.test node_modules/drizzle-kit/bin.cjs migrate",
    "db:studio": "tsx --env-file .env node_modules/drizzle-kit/bin.cjs studio",
    "pretest": "pnpm run db:migrate:test",
    "pretest:watch": "pnpm run db:migrate:test"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1018.0",
    "@aws-sdk/lib-storage": "^3.1018.0",
    "@fastify/cors": "^11.0.1",
    "@fastify/swagger": "^9.4.0",
    "@fastify/swagger-ui": "^5.2.0",
    "csv-stringify": "^6.6.0",
    "dayjs": "^1.11.13",
    "drizzle-orm": "^0.44.3",
    "fastify": "^5.2.0",
    "fastify-type-provider-zod": "^4.0.2",
    "postgres": "^3.4.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@faker-js/faker": "^9.9.0",
    "@types/node": "^24.0.0",
    "drizzle-kit": "^0.31.4",
    "tsup": "^8.5.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
